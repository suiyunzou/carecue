# ============================================================
# CareCue 配置模板（复制为 .env 后填写真实值）
# 修改后需重启 npm run dev:api（tsx watch 不监听 .env 变化）
# ============================================================

# ---------- 服务端基础 ----------
# PostgreSQL 连接串（prisma + 业务数据）
DATABASE_URL="postgresql://carecue:carecue@localhost:5432/carecue?schema=public"
# JWT 签名密钥（生产环境必须替换为长随机串）
JWT_SECRET="replace-with-a-long-random-secret"
# API 监听端口 / 地址
PORT="4300"
HOST="127.0.0.1"
# 允许的前端来源（CORS，多个用英文逗号分隔）
CLIENT_ORIGIN="http://127.0.0.1:5173,http://localhost:5173"

# ---------- 前端 ----------
# 前端请求的 API 基地址；留空则使用 Vite 代理 /api
VITE_API_BASE_URL=""

# ---------- LLM（OpenRouter）----------
# 必须 AI_ENABLED=true 且 OPENROUTER_API_KEY 非空，agent 才会调用 LLM；
# 否则全部走词典/规则/模板降级路径
AI_ENABLED="false"
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-api-key"
# 主模型 / 失败时的回退模型
OPENROUTER_MODEL="deepseek/deepseek-v4-pro"
OPENROUTER_FALLBACK_MODEL="deepseek/deepseek-v4-flash"
# OpenRouter 统计用请求头（可选）
OPENROUTER_REFERER="http://localhost:5173"
OPENROUTER_APP_TITLE="CareCue"
# 单次 LLM 调用超时（毫秒）
AI_TIMEOUT_MS="20000"
# 模型不支持 OpenAI 结构化输出（json_schema）时设为 false，跳过注定失败的 json_schema 首次请求，
# 直接使用 json_object，可显著降低每步 LLM 延迟。留空/true 时首次遇到 response_format 报错会自动降级并记忆。
OPENROUTER_JSON_SCHEMA="true"

# ---------- 联网医学检索（Firecrawl）----------
# 不配置则搜索全部失败，报告会标注"未经联网核验"
FIRECRAWL_API_KEY="fc-your-firecrawl-api-key"
# 联网检索总开关：设为 false 则 Agent 完全跳过联网核查（节省成本与时间，报告仅基于对话信息）
AGENT_WEB_SEARCH_ENABLED="true"

# ---------- Agent 行为 ----------
# 决策模式：llm（默认，LLM 决策+代码约束修正）| deterministic（全程代码确定性决策，最快但不主动追问）
AGENT_DECIDE_MODE="llm"

# ---------- Agent 调试 ----------
# 关键 LLM 调用日志（每步耗时/token）。设为 false 关闭；默认开启，便于排查响应慢的瓶颈步骤
AGENT_LLM_LOG="true"
# true 时在控制台打印全链路 Trace 日志（state_merged / risk_assessed / search_queries 等）
AGENT_TRACE_VERBOSE="false"
# 生产环境是否开放 /api/agent/cases/:caseId/debug 调试面板（开发环境始终可用）
AGENT_DEBUG_PANEL="false"
